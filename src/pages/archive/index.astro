---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getVisiblePosts, toMonthKey } from "../../components/blog-utils";

const posts = getVisiblePosts(await getCollection("blog"));
const monthMap = new Map<string, number>();

for (const post of posts) {
  const month = toMonthKey(post.data.date);
  monthMap.set(month, (monthMap.get(month) ?? 0) + 1);
}

const months = [...monthMap.entries()].sort(([a], [b]) => (a < b ? 1 : -1));
---

<MainLayout title="월별 아카이브 | Moonlog" description="월별 글 목록">
  <h1>월별 아카이브</h1>
  <div class="chips">
    {months.map(([month, count]) => <a class="chip" href={`/archive/${month}`}>{month} ({count})</a>)}
  </div>
</MainLayout>

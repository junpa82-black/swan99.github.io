---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { formatDate, getVisiblePosts, toMonthKey, toSlugPart } from "../../components/blog-utils";

const posts = getVisiblePosts(await getCollection("blog"));

const tagMap = new Map<string, number>();
const categoryMap = new Map<string, number>();
const monthMap = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
  categoryMap.set(post.data.category, (categoryMap.get(post.data.category) ?? 0) + 1);
  const key = toMonthKey(post.data.date);
  monthMap.set(key, (monthMap.get(key) ?? 0) + 1);
}
---

<MainLayout title="Moonlog | Blog" description="블로그 글 목록">
  <h1>Blog</h1>
  <p class="muted">글은 `src/content/blog/YYYY-MM/` 폴더 단위로 월별 관리할 수 있습니다.</p>

  <div class="grid" style="margin: 1rem 0 2rem;">
    {
      posts.map((post) => (
        <article class="post-card">
          <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
          <p class="muted">{post.data.description}</p>
          <div class="meta">
            <span>{formatDate(post.data.date)}</span>
            <span>
              카테고리:
              <a href={`/categories/${toSlugPart(post.data.category)}`}> {post.data.category}</a>
            </span>
          </div>
          <div class="chips">
            {post.data.tags.map((tag) => <a class="chip" href={`/tags/${toSlugPart(tag)}`}>#{tag}</a>)}
          </div>
        </article>
      ))
    }
  </div>

  <section class="post-card">
    <h3>분류 바로가기</h3>
    <p><strong>태그</strong></p>
    <div class="chips">
      {[...tagMap.entries()].map(([tag, count]) => <a class="chip" href={`/tags/${toSlugPart(tag)}`}>{tag} ({count})</a>)}
    </div>
    <p><strong>카테고리</strong></p>
    <div class="chips">
      {[...categoryMap.entries()].map(([category, count]) => <a class="chip" href={`/categories/${toSlugPart(category)}`}>{category} ({count})</a>)}
    </div>
    <p><strong>월별</strong></p>
    <div class="chips">
      {[...monthMap.entries()].map(([month, count]) => <a class="chip" href={`/archive/${month}`}>{month} ({count})</a>)}
    </div>
  </section>
</MainLayout>

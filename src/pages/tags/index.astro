---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getVisiblePosts, toSlugPart } from "../../components/blog-utils";

const posts = getVisiblePosts(await getCollection("blog"));
const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
---

<MainLayout title="태그 목록 | Moonlog" description="태그별 글 모아보기">
  <h1>태그</h1>
  <div class="chips">
    {[...tagMap.entries()].map(([tag, count]) => <a class="chip" href={`/tags/${toSlugPart(tag)}`}>{tag} ({count})</a>)}
  </div>
</MainLayout>
